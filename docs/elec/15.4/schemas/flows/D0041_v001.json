      "cardinality": {
        "min": 1,
        "max": 1
      },
      "condition": "",
      "fields": [
        {
          "ref": "J0073",
          "name": "Settlement Date",
          "format": "DATE(0)",
          "required": true
        },
        {
          "ref": "J0146",
