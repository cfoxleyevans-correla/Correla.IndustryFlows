{
  "$schema": "https://example.com/dtc/flow-schema/v1",
  "flowId": "D0378",
  "flowVersion": "001",
  "flowName": "BM Unit Aggregated Half Hour Demand Disconnection Data File",
  "status": "Operational",
  "ownership": "BSC",
  "description": "Aggregated line loss adjusted HH disconnection volumes in a GSP Group by Supplier and BM Unit.",
  "routes": [
    {
      "from": "HHDA",
      "to": "Supplier",
      "version": "15.4"
    },
    {
      "from": "HHDA",
      "to": "SVAA",
      "version": "15.4"
    }
  ],
  "groups": {
