{
  "$schema": "https://example.com/dtc/flow-schema/v1",
  "flowId": "D0317",
  "flowVersion": "001",
  "flowName": "Create New Green Deal Plan",
  "status": "Operational",
  "ownership": "MRA",
  "description": "Request for Green Deal Plan Id to be created.",
  "routes": [
    {
      "from": "GD Provider",
      "to": "GDCC",
      "version": "15.4"
    }
  ],
  "groups": {
    "86G": {
      "name": "Initial Plan Information",
      "parent": null,
      "level": 1,
      "cardinality": {
        "min": 1,
        "max": null
      },
      "condition": "",
      "fields": [
        {
          "ref": "J1818",
          "name": "Party Instruction Number",
          "format": "INT(20)",
          "required": true
        },
        {
          "ref": "J1753",
          "name": "EPC Register Indicator",
          "format": "CHAR(1)",
          "required": true
        },
        {
          "ref": "J1751",
          "name": "EPC Domestic or Non-Domestic Indicator",
          "format": "CHAR(1)",
          "required": true
        },
        {
          "ref": "J1752",
          "name": "EPC Property Reference Number",
          "format": "CHAR(30)",
          "required": true
        },
        {
          "ref": "J1754",
          "name": "EPC Report Reference",
          "format": "CHAR(30)",
          "required": true
        },
        {
          "ref": "J0757",
          "name": "Postcode",
          "format": "CHAR(10)",
          "required": true
        },
        {
          "ref": "J1750",
          "name": "Electricity Account Number",
          "format": "CHAR(20)",
          "required": true
        },
        {
          "ref": "J1777",
          "name": "GD Customer Site Reference",
          "format": "CHAR(20)",
          "required": false
        },
        {
          "ref": "J1831",
          "name": "Green Deal Provider Registration Reference",
          "format": "CHAR(7)",
          "required": true
        },
        {
          "ref": "J1832",
          "name": "GD Provider Plan Creator",
          "format": "CHAR(1)",
          "required": true
        }
      ]
    },
    "87G": {
      "name": "MPAN Core(s)",
      "parent": "86G",
      "level": 2,
      "cardinality": {
        "min": 1,
        "max": null
      },
      "condition": "",
      "fields": [
        {
          "ref": "J0003",
          "name": "MPAN Core",
          "format": "NUM(13)",
          "required": true
        }
      ]
    },
    "88G": {
      "name": "Subsidiary PRNS",
      "parent": "86G",
      "level": 2,
      "cardinality": {
        "min": 0,
        "max": 1
      },
      "condition": "",
      "fields": [
        {
          "ref": "J1821",
          "name": "Subsidiary EPC Property Reference",
          "format": "CHAR(20)",
          "required": true
        }
      ]
    }
  },
  "rules": [],
  "notes": "Any information entered in Group 88G will not be stored by the GDCC as subsidiary EPC Property References are no longer requried.Where the request to create a new Green Deal Plan is generated by the Green Deal Provider the GD Provider Plan Creator Code should be set to \"P\", where this request is generated by a GDAA Finance Party the GD Provider Plan Creator Code should be set to \"A\".The Green Deal Provider Registration Reference for the Green Deal Provider must be provided in all cases, including where the GD Provider is also a Green Deal Provider (as distinct from being a GDAA Finance Party)."
}