      "to": "CM Settlement Services Provider",
      "version": "15.4"
    },
    {
      "from": "HHDA",
      "to": "Supplier",
      "version": "15.4"
    },
    {
      "from": "SVAA",
      "to": "CFD Settlement Services Provider",
      "version": "15.4"
    },
    {
      "from": "SVAA",
      "to": "CM Settlement Services Provider",
      "version": "15.4"
    }
  ],
