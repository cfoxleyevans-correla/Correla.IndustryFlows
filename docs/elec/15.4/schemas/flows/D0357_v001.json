{
  "$schema": "https://example.com/dtc/flow-schema/v1",
  "flowId": "D0357",
  "flowVersion": "001",
  "flowName": "Half Hourly Metered Data for EMR",
  "status": "Operational",
  "ownership": "BSC",
  "description": "Half Hourly metered data for use by the CM Settlement Services Provider in calculating CM data, and/ or by the CFD Settlement Services provider in calculating CFD data.",
  "routes": [
    {
      "from": "HHDA",
      "to": "CFD Settlement Services Provider",
      "version": "15.4"
    },
    {
