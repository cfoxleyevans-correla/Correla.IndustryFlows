      },
      "condition": "",
      "fields": [
        {
          "ref": "J0330",
          "name": "File Sequence Number",
          "format": "INT(12)",
          "required": true
        }
      ]
    },
    "84H": {
      "name": "Rejection Details",
      "parent": "83H",
      "level": 2,
      "cardinality": {
        "min": 1,
        "max": null
