{
  "$schema": "https://example.com/dtc/flow-schema/v1",
  "flowId": "D0351",
  "flowVersion": "001",
  "flowName": "Rejection of Update to DCC Service Flag",
  "status": "Operational",
  "ownership": "MRA",
  "description": "Used to reject invalid changes to the DCC Service Flag.",
  "routes": [
    {
